# 复制本文件为 .env 并填入真实配置：cp .env.example .env

# ===== 大模型配置（OpenAI 兼容接口）=====
# 可切换 DeepSeek / OpenAI / 本地 Qwen / Llama，只需改 base_url 与 model
#   DeepSeek : https://api.deepseek.com/v1  | deepseek-chat (V3) / deepseek-reasoner (R1)
#   OpenAI   : https://api.openai.com/v1    | gpt-4o
#   Ollama   : http://localhost:11434/v1    | qwen2.5
OPENAI_API_KEY=sk-your-key-here
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1

# ===== HuggingFace 国内镜像（模型下载免魔法）=====
HF_ENDPOINT=https://hf-mirror.com

# ===== 模型选型（固定）=====
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RERANK_MODEL=BAAI/bge-reranker-base

# ===== 向量库 =====
CHROMA_DIR=./data/chroma
COLLECTION_NAME=enterprise_kb

# ===== 检索参数默认值 =====
TOP_K=5
SCORE_THRESHOLD=0.3
ENABLE_HYDE=false
ENABLE_PII=true
# char=递归字符分块；token=轻量 token 估算分块
CHUNK_STRATEGY=char
CHUNK_SIZE=800
CHUNK_OVERLAP=150
SUMMARY_MAX_TOKENS=2000
SUMMARY_KEEP_RECENT=4

# ===== OCR（默认关闭）=====
# 开启后支持图片 OCR 和扫描版 PDF OCR；云端 OCR 会把图片/页面发送到配置的视觉模型服务。
ENABLE_OCR=false
OCR_PROVIDER=qwen-vl
OCR_MODEL=qwen-vl-ocr-latest
OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OCR_API_KEY=
OCR_MAX_PAGES=20
OCR_DPI=180
OCR_PDF_MIN_TEXT_CHARS=30

# ===== 服务端口 =====
API_HOST=127.0.0.1
API_PORT=8000
UI_PORT=7860
AUTO_OPEN_BROWSER=true
